<?xml version="1.0" ?>

<sdf version="1.6">
  <world name="thermal_world">
  
  <scene>
    <sky>
      <cubemap_uri>file:///home/dkhuttan/projects/radiometric_thermal_sim/media/skybox/skybox.exr</cubemap_uri>
    </sky>
  </scene>

    <physics name="1ms" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>
    <plugin
      filename="gz-sim-physics-system"
      name="gz::sim::systems::Physics">
    </plugin>

    <plugin
      filename="gz-sim-user-commands-system"
      name="gz::sim::systems::UserCommands">
    </plugin>

    <plugin
      filename="gz-sim-scene-broadcaster-system"
      name="gz::sim::systems::SceneBroadcaster">
    </plugin>

    <plugin
      filename="gz-sim-sensors-system"
      name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>

    <!-- No world-level "Thermal" system plugin here on purpose: it requires
         <temperature> or <heat_signature> and would fail to load with
         neither. The Thermal system only needs to be declared once, right
         where a temperature is actually being set (see box_visual below);
         gz-sim loads it on demand. This matches gz-sim's own
         /usr/share/gz/gz-sim9/worlds/thermal_camera.sdf reference world. -->

    <plugin
      filename="/home/dkhuttan/projects/radiometric_thermal_sim/plugins/radiometric_thermal_sensor/build/libRadiometricThermalSensor.so"
      name="gz::sim::systems::RadiometricThermalSensor">
      <save_path>/home/dkhuttan/projects/radiometric_thermal_sim/output/radiometric</save_path>
      <!-- min_temp/max_temp/resolution MUST match the ThermalSensor plugin
           on the thermal_camera sensor below, or decoded temperatures will
           be wrong. gz-sim's actual encoding is temp = raw * resolution
           (min_temp/max_temp only clamp the input temperature, they are not
           an offset). 0.01 K/count is gz-sim's own default for L16 and gives
           a representable range up to 655.35K, comfortably above max_temp. -->
      <min_temp>253.15</min_temp>
      <max_temp>373</max_temp>
      <resolution>0.01</resolution>
    </plugin>

    <plugin
      filename="/home/dkhuttan/projects/radiometric_thermal_sim/plugins/radiometric_depth_sensor/build/libRadiometricDepthSensor.so"
      name="gz::sim::systems::RadiometricDepthSensor">
      <save_path>/home/dkhuttan/projects/radiometric_thermal_sim/output/depth</save_path>
    </plugin>

    <gui fullscreen="0">

      <!-- 3D scene -->
      <plugin filename="GzScene3D" name="3D View">
        <ignition-gui>
          <title>3D View</title>
          <property type="bool" key="showTitleBar">false</property>
          <property type="string" key="state">docked</property>
        </ignition-gui>

        <engine>ogre2</engine>
        <scene>scene</scene>
        <ambient_light>0.4 0.4 0.4</ambient_light>
        <background_color>0.8 0.8 0.8</background_color>
        <camera_pose>-6 0 6 0 0.5 0</camera_pose>
      </plugin>

      <!-- World control -->
      <plugin filename="WorldControl" name="World control">
        <ignition-gui>
          <title>World control</title>
          <property type="bool" key="showTitleBar">false</property>
          <property type="bool" key="resizable">false</property>
          <property type="double" key="height">72</property>
          <property type="double" key="width">121</property>
          <property type="double" key="z">1</property>

          <property type="string" key="state">floating</property>
          <anchors target="3D View">
            <line own="left" target="left"/>
            <line own="bottom" target="bottom"/>
          </anchors>
        </ignition-gui>

        <play_pause>true</play_pause>
        <step>true</step>
        <start_paused>true</start_paused>
        <service>/world/thermal_camera/control</service>
        <stats_topic>/world/thermal_camera/stats</stats_topic>

      </plugin>

      <!-- World statistics -->
      <plugin filename="WorldStats" name="World stats">
        <ignition-gui>
          <title>World stats</title>
          <property type="bool" key="showTitleBar">false</property>
          <property type="bool" key="resizable">false</property>
          <property type="double" key="height">110</property>
          <property type="double" key="width">290</property>
          <property type="double" key="z">1</property>

          <property type="string" key="state">floating</property>
          <anchors target="3D View">
            <line own="right" target="right"/>
            <line own="bottom" target="bottom"/>
          </anchors>
        </ignition-gui>

        <sim_time>true</sim_time>
        <real_time>true</real_time>
        <real_time_factor>true</real_time_factor>
        <iterations>true</iterations>
        <topic>/world/thermal_camera/stats</topic>
      </plugin>

      <plugin filename="ImageDisplay" name="Image Display">
        <ignition-gui>
          <title>Thermal camera</title>
          <property key="state" type="string">floating</property>
          <property type="double" key="width">350</property>
          <property type="double" key="height">315</property>
        </ignition-gui>
        <topic>thermal/image</topic>
        <topic_picker>false</topic_picker>
      </plugin>
      <plugin filename="ImageDisplay" name="Image Display RGB">
        <ignition-gui>
          <title>Thermal camera</title>
          <property key="state" type="string">floating</property>
          <property type="double" key="width">350</property>
          <property type="double" key="height">315</property>
          <property type="double" key="x">500</property>
        </ignition-gui>
        <topic>rgb/image</topic>
        <topic_picker>false</topic_picker>
      </plugin>

    </gui>

    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <atmosphere type="adiabatic">
      <temperature>300</temperature>
      <!--
        This is a more exaggerated temperature gradient, which produces a
        temperature range of ~11.5 kelvin for objects in the thermal camera
        view. Typical temperature gradient is -0.0065 K/m which produces a
        temperature range of 0.75 kelvin
      -->
      <temperature_gradient>0.1</temperature_gradient>
    </atmosphere>




    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box>
              <size>20 20 0.1</size>
            </box>
          </geometry>
        </collision>
        <!--
        <visual name="visual">
          <geometry>
            <box>
              <size>20 20 0.1</size>
            </box>
          </geometry>
          <material>
            <ambient>0.8 0.8 0.8 1</ambient>
            <diffuse>0.8 0.8 0.8 1</diffuse>
            <specular>0.8 0.8 0.8 1</specular>
          </material>
          <plugin
            filename="gz-sim-thermal-system"
            name="gz::sim::systems::Thermal">
            <temperature>290.0</temperature>
          </plugin>
        </visual> -->
        
      </link>
    </model>

    <model name="box">
      <static>false</static>
      <pose>-1 1 0.5 0 0 0</pose>
      <link name="box_link">
        <inertial>
          <inertia>
            <ixx>1</ixx>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyy>1</iyy>
            <iyz>0</iyz>
            <izz>1</izz>
          </inertia>
          <mass>1.0</mass>
        </inertial>
        <collision name="box_collision">
          <geometry>
            <box>
              <size>1 1 1</size>
            </box>
          </geometry>
        </collision>

        <visual name="box_visual">
          <geometry>
            <box>
              <size>1 1 1</size>
            </box>
          </geometry>
          <material>
            <ambient>1 0 0 1</ambient>
            <diffuse>1 0 0 1</diffuse>
            <specular>1 0 0 1</specular>
          </material>
          <plugin
            filename="gz-sim-thermal-system"
            name="gz::sim::systems::Thermal">
            <temperature>280.0</temperature>
          </plugin>
        </visual>
      </link>
    </model>





    <model name="camera_rig">
      <static>true</static>
      <pose>7 0 0.7 0 0 3.14</pose>
      <link name="cam_link">
        
         <!-- x y z roll pitch yaw -->
        <visual name="rig_box">
          <geometry>
            <box>
              <size>0.3 0.3 0.3</size>
            </box>
          </geometry>
          <material>
            <ambient>0.1 0.7 1.0 1</ambient>
          </material>
        </visual>

        <sensor name="rgb_cam" type="camera">
          <pose>0 0.05 0 0 0 0</pose>
          <always_on>1</always_on>
          <update_rate>20</update_rate>
          <visualize>false</visualize>
          <topic>/rgb/image</topic>
          <camera>
            <save enabled="true">
              <path>/home/dkhuttan/projects/radiometric_thermal_sim/output/rgb</path>
            </save>
            <image>
              <width>1280</width>
              <height>720</height>
              <format>R8G8B8</format>
            </image>
            <clip><near>0.05</near><far>200</far></clip>
          </camera>
        </sensor>

        <!-- Ground-truth depth for validating the thermal->RGB reprojection
             (the rgbt repo). Placed exactly at rgb_cam's pose with the same
             resolution and FOV, so the depth map is natively in the RGB
             camera's frame -- rgb_cam has no explicit horizontal_fov and
             falls back to the SDF default of 1.047, so the explicit 1.047
             here keeps them matched. Depth pixels are float32 z-depth in
             meters (planar, not Euclidean range); inf = nothing hit within
             the far clip. -->
        <sensor name="depth_camera" type="depth_camera">
          <pose>0 0.05 0 0 0 0</pose>
          <always_on>1</always_on>
          <update_rate>20</update_rate>
          <visualize>false</visualize>
          <topic>/depth/image</topic>
          <camera>
            <horizontal_fov>1.047</horizontal_fov>
            <image>
              <width>1280</width>
              <height>720</height>
              <format>R_FLOAT32</format>
            </image>
            <clip><near>0.05</near><far>200</far></clip>
          </camera>
        </sensor>

        <sensor name="thermal_camera" type="thermal">
          <camera>
            <save enabled="true">
              <path>/home/dkhuttan/projects/radiometric_thermal_sim/output/thermal</path>
            </save>
            <horizontal_fov>1.047</horizontal_fov>
            <image>
              <width>320</width>
              <height>240</height>
              <format>L16</format>
            </image>
            <clip>
              <near>0.1</near>
              <far>100</far>
            </clip>
          </camera>
          <always_on>1</always_on>
          <update_rate>20</update_rate>
          <visualize>true</visualize>
          <topic>/thermal/image</topic>
          <plugin
            filename="gz-sim-thermal-sensor-system"
            name="gz::sim::systems::ThermalSensor">
            <!-- MUST match min_temp/max_temp/resolution on the
                 RadiometricThermalSensor plugin above, or decoded
                 temperatures will be wrong. -->
            <min_temp>253.15</min_temp>
            <max_temp>373</max_temp>
            <resolution>0.01</resolution>
          </plugin>
        </sensor>
      </link>
    </model>



    <include>
      <pose>1 0 0 0 0 1.570796</pose>
      <name>rescue_randy</name>
      <uri>https://fuel.ignitionrobotics.org/1.0/OpenRobotics/models/Rescue Randy</uri>
    </include>

    <include>
      <pose>2.25 .5 .1 0 0 1.570796</pose>
      <name>phone</name>
      <uri>https://fuel.ignitionrobotics.org/1.0/OpenRobotics/models/Samsung J8 Black</uri>
    </include>

    <include>
      <pose>2.25 -.5 .1 0 0 1.570796</pose>
      <name>backpack</name>
      <uri>https://fuel.ignitionrobotics.org/1.0/OpenRobotics/models/Backpack</uri>
    </include>
<!--
    <include>
      <pose>0 0 -0.5 0 0 0</pose>
      <name>terrain</name>
      <uri>https://fuel.gazebosim.org/1.0/jasmeetsingh/models/Mars Gale Crater Patch 2</uri>
    </include> 


    <include>
      <pose>0 5 0 0 0 0</pose>
      <name>campus</name>
      <uri>https://fuel.gazebosim.org/1.0/hujp/models/Campus</uri>
    </include>
    -->


    <include>
      <pose>230 10 -1.4 0 0 0</pose>
      <name>campus</name>
      <uri>https://fuel.gazebosim.org/1.0/bdilman/models/baylands_2</uri>
    </include>

  </world>
</sdf>